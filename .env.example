# Copy this file to .env and fill in the values. .env is gitignored.

# --- Discord (required) ---------------------------------------------------
# Bot token from https://discord.com/developers/applications -> your app -> Bot
DISCORD_TOKEN=

# Optional but recommended while developing: your server's ID. Slash commands
# sync to this guild instantly. Leave blank to register globally (~1h to show).
DISCORD_GUILD_ID=

# Optional: set to 1 to register Lorehound as a user-installable app so its
# commands work in DMs and private group chats (group DMs), not just servers.
# First enable "User Install" in the Discord Developer Portal
# (your app -> Installation -> Installation Contexts -> User Install), then set
# this and restart. Commands go global, so they can take ~1h to appear.
LOREHOUND_USER_INSTALL=

# --- Google Drive (optional until you set up the rules feature) -----------
# The ID of the Drive folder holding your rules docs/PDFs. It's the long string
# in the folder URL: https://drive.google.com/drive/folders/<THIS_PART>
DRIVE_FOLDER_ID=

# Provide credentials ONE of two ways:
# 1) Path to the service-account key file (best for local dev):
GOOGLE_CREDENTIALS_FILE=service_account.json
# 2) OR the raw JSON of the key as a single line (best for cloud hosts that
#    only let you set env vars). If set, this takes precedence over the file.
GOOGLE_CREDENTIALS_JSON=

# --- Advanced / diagnostics (optional) ------------------------------------
# Set to 1 for a one-shot self-test: Lorehound logs in, syncs its slash
# commands, confirms it all works, then shuts down (it does NOT stay running).
# Useful for verifying a new token or a fresh deployment. Leave blank normally.
LOREHOUND_SMOKE_TEST=
